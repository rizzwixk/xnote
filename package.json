{
  "name": "xnote",
  "version": "1.1.2",
  "description": "A minimal grayscale notes app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.xnote.app",
    "productName": "xnote",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "node_modules/**/*",
      "!node_modules/electron/**"
    ],
    "icon": "build/icon.ico",
    "win": {
      "target": "portable"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": null,
      "uninstallerIcon": null,
      "installerHeaderIcon": null
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "@lottiefiles/dotlottie-web": "^0.78.2",
    "lottie-web": "^5.13.0",
    "lucide": "^1.26.0",
    "sharp": "^0.35.3"
  }
}
